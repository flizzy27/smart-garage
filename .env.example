# Smart Garage — Docker / Unraid environment variables
# Set these in the Unraid template UI or docker-compose.
# Do not commit a real .env file.

# SQLite (single-container; file lives on the /data volume in Docker)
DATABASE_URL=file:/data/smart-garage.db

# Local development (outside Docker):
# DATABASE_URL=file:../data/smart-garage.db
# UPLOAD_DIR=../data/uploads

UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=25
MAX_IMAGE_SIZE_MB=10
NODE_ENV=production

# Session cookie Secure flag: unset = works on HTTP and HTTPS (Unraid LAN default)
# SESSION_COOKIE_SECURE=true   # HTTPS-only deployments
# SESSION_COOKIE_SECURE=auto   # secure when X-Forwarded-Proto is https
