# =============================================================================
# Smart Garage — environment variables
# Copy to .env and adjust values. Never commit .env to version control.
# =============================================================================

# Default UI locale (next-intl) — English default; German (de) also supported
DEFAULT_LOCALE=en

# SQLite database (development). File is created on first migration.
DATABASE_URL=file:../data/smart-garage.db

# Local file uploads (relative to frontend/)
UPLOAD_DIR=../data/uploads
MAX_IMAGE_SIZE_MB=10

# --- Authentication (required when auth is implemented) -------------------------
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (used for auth callbacks)
APP_URL=http://localhost:3000
AUTH_TRUST_HOST=false

# --- Registration -------------------------------------------------------------
REGISTRATION_MODE=open
FIRST_USER_IS_ADMIN=true

# --- File storage (required when uploads are implemented) -----------------------
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25
MAX_IMAGE_SIZE_MB=10

# --- Docker Compose (production — used when docker-compose.yml is added) --------
POSTGRES_USER=smartgarage
POSTGRES_PASSWORD=
POSTGRES_DB=smartgarage
APP_PORT=3000

# --- Optional (future) --------------------------------------------------------
# STORAGE_DRIVER=local
# LOG_LEVEL=info
